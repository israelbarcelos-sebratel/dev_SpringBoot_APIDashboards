# Modelo de variáveis para o docker-compose das APIs Java.
# Copie para `.env` (que é ignorado pelo git) e preencha os valores reais.
#   cp .env.example .env

# Banco de dados (MariaDB)
DB_HOST=10.0.11.171
DB_PORT=3306
DB_NAME=API_WebDeveloper
DB_USER=DevSebratel
DB_PASSWORD=

# Origens permitidas para CORS (BFF). Opcional — há defaults no compose.
MATRIX_BFF_ORIGIN=http://localhost:4001
NATIVE_BFF_ORIGIN=http://localhost:4002
